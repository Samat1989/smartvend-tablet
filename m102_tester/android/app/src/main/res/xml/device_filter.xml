<?xml version="1.0" encoding="utf-8"?>
<!--
    USB host intent-filter for auto-launching the app when the M109E's
    inline USB-Serial adapter is attached. Mirrors the factory app's
    UsbUtil.findUSB which only accepts vid=0x1A86 pid=0x7523 (CH340).

    Decimal equivalents (Android requires both forms):
      0x1A86 = 6790
      0x7523 = 29987
-->
<resources>
    <usb-device vendor-id="6790" product-id="29987" />
</resources>
