# --- Decompiled factory app ----------------------------------------------
# Reverse-engineered sources of `com.shengma.huishu.hasakesitan` (Yi-Pu-Teng).
# Useful for grep + reading, but: tens of thousands of files, copyright-
# encumbered, and easily regenerated from the original APK with jadx /
# apktool. Do NOT commit.
snack_jadx/
snack_apktool/

# --- Build / patching scratch -------------------------------------------
_patch_tmp/

# --- Binaries we can rebuild --------------------------------------------
# Signed/unsigned APKs and sidecar files. Big, can be reproduced via
# `flutter build apk` for the new app or apktool for the legacy patches.
*.apk
*.apk.idsig

# --- Signing material (NEVER commit) ------------------------------------
# Release keystore + per-environment credentials. Production releases
# are signed in CI from GitHub Secrets, locally from a dev's own copy.
*.jks
*.keystore
key.properties
**/android/key.properties

# --- Release credentials (NEVER commit) ---------------------------------
# Personal Access Token used by release.ps1. Fine-grained PAT scoped to
# `Contents: read+write` on Samat1989/smartvend-tablet. See header of
# release.ps1 for setup instructions.
.github_token

# Third-party tooling jars (downloaded separately when needed).
apktool*.jar
uber-apk-signer*.jar

# --- Local IDE / agent state --------------------------------------------
# Project-scope `.claude/settings.json` and `.mcp.json` ARE committed —
# they help future contributors (and the AI assistant) pick up where we
# left off. Only the personal local override is gitignored.
.claude/settings.local.json
# Lock file is runtime state, no value in source control. Use `**/`
# so it matches both `.claude/` at the root and inside `m102_tester/`.
**/.claude/scheduled_tasks.lock

# --- Python -------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# --- OS / editors -------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# --- Test screenshots ---------------------------------------------------
# May contain Kaspi QR codes / order ids — not safe to publish.
photo_*.jpg
photo_*.jpeg
photo_*.png
